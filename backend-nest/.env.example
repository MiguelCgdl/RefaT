# Configuración de Base de Datos para NestJS & Prisma
# ===================================================
#
# Copia este archivo a un nuevo archivo llamado '.env' en este mismo directorio
# y configura las variables según tu entorno de desarrollo.
# NOTA: El archivo '.env' está en .gitignore y no debe subirse a Git por seguridad.

# --- OPCIÓN A: Conexión Local (Recomendado para desarrollo rápido/offline) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=tu_contraseña_local_aqui
# DATABASE_URL=postgresql://postgres:tu_contraseña_local_aqui@localhost:5432/postgres?schema=public

# --- OPCIÓN B: Conexión Remota (Supabase Shared Pooler) ---
POSTGRES_DB=postgres
POSTGRES_USER=postgres.fzzbrvkdmrcdueovjtpt
POSTGRES_PASSWORD=M1k3010687**.
POSTGRES_HOST=aws-1-us-west-2.pooler.supabase.com
POSTGRES_PORT=6543

# IMPORTANTE: Los caracteres especiales de la contraseña en DATABASE_URL deben estar codificados en formato URL:
# - El carácter '*' se codifica como '%2A'
# - El carácter '.' se codifica como '%2E'
DATABASE_URL=postgresql://postgres.fzzbrvkdmrcdueovjtpt:M1k3010687%2A%2A%2E@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# --- Configuración del Servidor NestJS API ---
PORT=3001
JWT_SECRET=cambiar-en-produccion-jwt-secreto-largo
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- Configuración de Redis / BullMQ ---
# Habilita y configura si usas colas de tareas en segundo plano locales
# REDIS_URL=redis://localhost:6379

# --- URL del Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
