generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("ADMIN") // ADMIN, MECANICO
  createdAt DateTime @default(now())
}

model Cliente {
  id        Int        @id @default(autoincrement())
  nombre    String
  email     String?
  telefono  String
  createdAt DateTime   @default(now())
  vehiculos Vehiculo[]
  ordenes   Orden[]
}

model Vehiculo {
  id          Int      @id @default(autoincrement())
  placas      String   @unique
  marca       String
  modelo      String
  anio        Int
  color       String?
  motor       String?
  kilometraje Int?
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  ordenes     Orden[]
}

model Refaccion {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  stock       Int      @default(0)
  marca       String?
  numeroParte String?
  createdAt   DateTime @default(now())
  
  ordenes     OrdenRefaccion[]
}

model Orden {
  id                 Int      @id @default(autoincrement())
  clienteId          Int
  vehiculoId         Int
  descripcion        String
  problemasReportados String? 
  estado             String   @default("PENDIENTE") // PENDIENTE, ENVIADO, AUTORIZADO, RECHAZADO, COMPLETADO
  costoManoObra      Float    @default(0)
  total              Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  vehiculo      Vehiculo @relation(fields: [vehiculoId], references: [id])
  refacciones   OrdenRefaccion[]
}

model OrdenRefaccion {
  id          Int       @id @default(autoincrement())
  ordenId     Int
  refaccionId Int
  cantidad    Int
  precioUnidad Float
  
  orden       Orden     @relation(fields: [ordenId], references: [id])
  refaccion   Refaccion @relation(fields: [refaccionId], references: [id])

  @@unique([ordenId, refaccionId])
}
