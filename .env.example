# Base de datos
POSTGRES_DB=refa_db
POSTGRES_USER=refa_user
POSTGRES_PASSWORD=refa_pass
# localhost si corres el backend en tu máquina; docker-compose usa POSTGRES_HOST=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=cambiar-en-produccion-clave-secreta-larga
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api
