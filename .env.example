# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/postgres?schema=public

# Supabase Configuration (for production)
# DB_HOST=aws-1-us-west-2.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.your_supabase_user
# DB_PASSWORD=your_supabase_password
# DB_SSL=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=8h

# Backend Server Configuration
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Admin User Configuration (for seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Optional: Email/Notification Services
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# SENDGRID_API_KEY=your_sendgrid_key
# WHATSAPP_API_TOKEN=your_whatsapp_token

# Redis Configuration (for queues)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Security Headers
HELMET_ENABLED=true

# Django Configuration (for Django backend)
DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_USE_SQLITE=false

# Django Database Configuration (if using Django with PostgreSQL)
POSTGRES_DB=refa_db
POSTGRES_USER=refa_user
POSTGRES_PASSWORD=your_django_db_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
